{
  "name": "botresearcher",
  "version": "1.0.0",
  "private": true,
  "description": "Telegram bot that monitors freelance marketplaces for new relevant jobs. Next.js App Router + TypeScript, deployable on Vercel.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:init": "tsx scripts/db-init.ts",
    "set-webhook": "tsx scripts/set-webhook.ts",
    "delete-webhook": "tsx scripts/set-webhook.ts --delete"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.0",
    "next": "^14.2.15",
    "postgres": "^3.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
