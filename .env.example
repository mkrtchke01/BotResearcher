# ----------------------------------------------------------------------------
# BotResearcher — environment variables
# Copy this file to `.env.local` for local development and fill in real values.
# NEVER commit real secrets. On Vercel, set these in Project Settings → Environment Variables.
# ----------------------------------------------------------------------------

# Telegram bot token from @BotFather (e.g. 123456789:AA...).
# REQUIRED. Read only from process.env.TELEGRAM_BOT_TOKEN — never hardcode it.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Default chat id that should always receive notifications (your own chat/group).
# Optional — users who send /start are also stored and notified.
TELEGRAM_CHAT_ID=your-numeric-chat-id-here

# Secret token sent by Telegram in the `X-Telegram-Bot-Api-Secret-Token` header.
# You choose this value; it is passed to setWebhook and validated on every update.
TELEGRAM_WEBHOOK_SECRET=choose-a-long-random-string

# Postgres connection string (Supabase or Neon). Must include sslmode=require.
# Supabase: use the "Connection pooling" (port 6543) string for serverless.
# Neon:     use the pooled connection string.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Secret used to authorize the cron route. Vercel Cron sends it automatically
# in the Authorization header when this var is set on the project.
CRON_SECRET=choose-another-long-random-string

# Public base URL of the deployed app (no trailing slash), used by helper scripts
# to register the Telegram webhook. e.g. https://botresearcher.vercel.app
APP_URL=https://your-app.vercel.app

# ----------------------------------------------------------------------------
# LaborX provider (optional — sensible defaults are built in)
# ----------------------------------------------------------------------------
# Base URL of the public LaborX job-board API. Override only for testing.
# LABORX_API_URL=https://api.laborx.com
# How many newest LaborX jobs to pull per cron run (1–50). Raise if you poll
# infrequently so no postings slip through between runs.
# LABORX_FETCH_LIMIT=50

# Cap on notifications sent per cron run. Unset / 0 = unlimited (send every
# fresh match). Set a positive integer only if you want to limit the first-run
# backlog flood. Telegram 429s are retried automatically, so unlimited is safe.
# MAX_NOTIFICATIONS_PER_CHECK=0

# Freshness window in hours: only notify about jobs posted within this many
# hours. Drops stale / bumped-up old postings. Default 24.
# MAX_JOB_AGE_HOURS=24
